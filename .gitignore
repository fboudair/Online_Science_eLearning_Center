# Ignore system files (macOS)
.DS_Store

# Ignore XAMPP, MAMP or similar local environment files
*.log
*.sql
*.sqlite

# Ignore IDE/editor config files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Ignore environment and config files (if any)
.env
config.php

# Ignore vendor directory if using Composer
/vendor/

# Ignore node_modules if you ever add frontend tools
/node_modules/

# Ignore cache/temp files
tmp/
cache/
*.bak
*.tmp

# Ignore screenshots (optional if you don't want to push them)
# /screenshots/
